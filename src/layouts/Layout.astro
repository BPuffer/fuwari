---
import "@fontsource/roboto/400.css";
import "@fontsource/roboto/500.css";
import "@fontsource/roboto/700.css";

import ConfigCarrier from "@components/ConfigCarrier.astro";
import { profileConfig, siteConfig } from "@/config";
import {
	AUTO_MODE,
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	BANNER_HEIGHT_HOME,
	DARK_MODE,
	DEFAULT_THEME,
	LIGHT_MODE,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
	PAGE_WIDTH,
} from "../constants/constants";
import { defaultFavicons } from "../constants/icon";
import type { Favicon } from "../types/config";
import { pathsEqual, url } from "../utils/url-utils";
import "katex/dist/katex.css";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
}

let { title, banner, description, lang, setOGTypeArticle } = Astro.props;

// apply a class to the body element to decide the height of the banner, only used for initial page load
// Swup can update the body for each page visit, but it's after the page transition, causing a delay for banner height change
// so use Swup hooks instead to change the height immediately when a link is clicked
const isHomePage = pathsEqual(Astro.url.pathname, url("/"));

// defines global css variables
// why doing this in Layout instead of GlobalStyles: https://github.com/withastro/astro/issues/6728#issuecomment-1502203757
const configHue = siteConfig.themeColor.hue;
if (!banner || typeof banner !== "string" || banner.trim() === "") {
	banner = siteConfig.banner.src;
}

// TODO don't use post cover as banner for now
banner = siteConfig.banner.src;

const enableBanner = siteConfig.banner.enable;
const enableBanner2 = siteConfig.banner2.enable;
if (enableBanner && enableBanner2) {
	throw new Error("Only one banner can be enabled at a time");
}

let pageTitle: string;
if (title) {
	pageTitle = `${title} - ${siteConfig.title}`;
} else {
	pageTitle = `${siteConfig.title} - ${siteConfig.subtitle}`;
}

const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

// const siteLang = siteConfig.lang.replace('_', '-')
if (!lang) {
	lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");

const bannerOffsetByPosition = {
	top: `${BANNER_HEIGHT_EXTEND}vh`,
	center: `${BANNER_HEIGHT_EXTEND / 2}vh`,
	bottom: "0",
};
const bannerOffset =
	bannerOffsetByPosition[siteConfig.banner.position || "center"];

const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";

const banner2Height = siteConfig.banner2.height;
const banner2HeightFix =
	typeof siteConfig.banner2.heightFix === "number"
		? siteConfig.banner2.heightFix
		: (siteConfig.banner2.waving.heightBottomMax - 100) / 2;
const banner2HeightM = siteConfig.banner2.mobileHeight || banner2Height;
const banner2HeightFixM =
	typeof siteConfig.banner2.mobileHeightFix === "number"
		? siteConfig.banner2.mobileHeightFix
		: banner2HeightM;

const banner2HeightNH = siteConfig.banner2.waving.nonHome.height;
const banner2HeightNM = siteConfig.banner2.mobileWaving.nonHome.height;

const banner2HeightNHFix =
	typeof siteConfig.banner2.waving.nonHome.heightFix === "number"
		? siteConfig.banner2.waving.nonHome.heightFix
		: (siteConfig.banner2.waving.heightBottomMax - 100) / 2;
const banner2HeightNMFix =
	typeof siteConfig.banner2.mobileWaving.nonHome.heightFix === "number"
		? siteConfig.banner2.mobileWaving.nonHome.heightFix
		: (siteConfig.banner2.mobileWaving.heightBottomMax ||
				siteConfig.banner2.waving.heightBottomMax - 100) / 2;
---

<!DOCTYPE html>
<html lang={siteLang} class="bg-[var(--page-bg)] transition text-[14px] md:text-[16px]">
	<head>

		<title>{pageTitle}</title>

		<meta charset="UTF-8" />
		<meta name="description" content={description || pageTitle}>
		<meta name="author" content={profileConfig.name}>

		<meta property="og:site_name" content={siteConfig.title}>
		<meta property="og:url" content={Astro.url}>
		<meta property="og:title" content={pageTitle}>
		<meta property="og:description" content={description || pageTitle}>
		{setOGTypeArticle ? (
        <meta property="og:type" content="article" />
        ) : (
        <meta property="og:type" content="website" />
        )}

		<meta name="twitter:card" content="summary_large_image">
		<meta property="twitter:url" content={Astro.url}>
		<meta name="twitter:title" content={pageTitle}>
		<meta name="twitter:description" content={description || pageTitle}>

		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		{favicons.map(favicon => (
			<link rel="icon"
				  href={favicon.src.startsWith('/') ? url(favicon.src) : favicon.src}
				  sizes={favicon.sizes}
				  media={favicon.theme && `(prefers-color-scheme: ${favicon.theme})`}
			/>
		))}

		<!-- Set the theme before the page is rendered to avoid a flash -->
		<script is:inline define:vars={{DEFAULT_THEME, LIGHT_MODE, DARK_MODE, AUTO_MODE, BANNER_HEIGHT_EXTEND, PAGE_WIDTH, configHue}}>
			// Load the theme from local storage
			const theme = localStorage.getItem('theme') || DEFAULT_THEME;
			switch (theme) {
				case LIGHT_MODE:
					document.documentElement.classList.remove('dark');
					break
				case DARK_MODE:
					document.documentElement.classList.add('dark');
					break
				case AUTO_MODE:
					if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
						document.documentElement.classList.add('dark');
					} else {
						document.documentElement.classList.remove('dark');
					}
			}

			// Load the hue from local storage
			const hue = localStorage.getItem('hue') || configHue;
			document.documentElement.style.setProperty('--hue', hue);

			// calculate the --banner-height-extend, which needs to be a multiple of 4 to avoid blurry text
			let offset = Math.floor(window.innerHeight * (BANNER_HEIGHT_EXTEND / 100));
			offset = offset - offset % 4;
			document.documentElement.style.setProperty('--banner-height-extend', `${offset}px`);
		</script>
		{ siteConfig.count.umamiCloud.enabled &&  
			<div set:html={siteConfig.count.umamiCloud.htmltag}></div>
		}
		<style define:vars={{
			configHue,
			'page-width': `${PAGE_WIDTH}rem`,
		}}></style>  <!-- defines global css variables. This will be applied to <html> <body> and some other elements idk why -->


		<slot name="head"></slot>

		<link rel="alternate" type="application/rss+xml" title={profileConfig.name} href={`${Astro.site}rss.xml`}/>

	</head>
	<body class=" min-h-screen transition " class:list={[{
		"is-home": isHomePage, 
		"enable-banner": enableBanner, 
		"enable-banner2": enableBanner2,
		"enable-b2nh": siteConfig.banner2.waving.nonHome.enable,
		"enable-b2nm": siteConfig.banner2.mobileWaving.nonHome.enable,
		"bg-fixed": enableBanner2}]}
	>
		<ConfigCarrier></ConfigCarrier>
		<slot />

		<!-- increase the page height during page transition to prevent the scrolling animation from jumping -->
		<div id="page-height-extend" class="hidden h-[300vh]"></div>
	</body>
</html>

<style is:global define:vars={{
	bannerOffset,
	'banner-height-home': `${BANNER_HEIGHT_HOME}vh`,
	'banner-height': `${BANNER_HEIGHT}vh`,
	
	'banner2-height-home-desktop': `${banner2Height}vh`,
	'banner2-content-height-home-desktop': `${banner2Height + banner2HeightFix}vh`,
	'banner2-height-nonhome-desktop': `${banner2HeightNH}vh`,
	'banner2-content-height-nonhome-desktop': `${banner2HeightNH + banner2HeightNHFix}vh`,
	'banner2-dbg': `url(${siteConfig.banner2.src.desktopBg})`,

	'banner2-height-home-mobile': `${banner2HeightM}vh`,
	'banner2-content-height-home-mobile': `${banner2HeightM + banner2HeightFixM}vh`,
	'banner2-height-nonhome-mobile': `${banner2HeightNM}vh`,
	'banner2-content-height-nonhome-mobile': `${banner2HeightNM + banner2HeightNMFix}vh`,
	'banner2-mbg': `url(${siteConfig.banner2.src.mobileBg})`,
	'main-panel-top': `${mainPanelTop}`,
}}>
:root {
	--top-row-height: calc(var(--banner-height-home) - 4.5rem);
}
body {
	/* background: repeating-linear-gradient(45deg, yellow 0, yellow 15px, gray 15px, gray 30px); */
    background: no-repeat center / cover;
}
@media (max-width: 768px) {
	body {
		background-image: var(--banner2-mbg);
	}
}
@media (min-width: 769px) {
	body {
		background-image: var(--banner2-dbg);
	}
}
@tailwind components;
@layer components {
	.enable-banner.is-home #banner-wrapper {
		@apply h-[var(--banner-height-home)] translate-y-[var(--banner-height-extend)]
	}
	.enable-banner #banner-wrapper {
		@apply h-[var(--banner-height-home)]
	}

	.enable-banner.is-home #banner {
		@apply h-[var(--banner-height-home)] translate-y-0
	}
	.enable-banner #banner {
		@apply h-[var(--banner-height-home)] translate-y-[var(--bannerOffset)]
	}
	.enable-banner.is-home #main-grid {
		@apply translate-y-[var(--banner-height-extend)];
	}
	.enable-banner #top-row {
		@apply h-[var(--top-row-height)] transition-all duration-300
	}
	.enable-banner.is-home #sidebar-sticky {
		@apply top-[calc(1rem_-_var(--banner-height-extend))]
	}
	.navbar-hidden {
		@apply opacity-0 -translate-y-16
	}
}
@layer components {
	/* 基本Banner2样式 */

	/* 非主页。只有这个case需要处理main-panel的translate */
	.enable-banner2 #banner2-container {
		opacity: 0;
		transition: opacity 0.3s ease;
		will-change: opacity;
	}

	/* 复杂的选择器是为了解决css特定性 */
	@media (min-width: 769px) {
		.enable-banner2.is-home #banner2-container, 
		.enable-banner2.enable-b2nh.is-home #banner2-container,
		.enable-banner2.enable-b2nm.is-home #banner2-container,
		.enable-banner2.enable-b2nh.enable-b2nm.is-home #banner2-container
		{
			height: var(--banner2-height-home-desktop);
		}
	}
	@media (max-width: 768px) {
		.enable-banner2.is-home #banner2-container, 
		.enable-banner2.enable-b2nh.is-home #banner2-container,
		.enable-banner2.enable-b2nm.is-home #banner2-container,
		.enable-banner2.enable-b2nh.enable-b2nm.is-home #banner2-container
		{
			height: var(--banner2-height-home-mobile);
		}
	}

	@media (min-width: 769px) {
		body.enable-banner2.is-home, 
		body.enable-banner2.enable-b2nh.is-home,
		body.enable-banner2.enable-b2nm.is-home,
		body.enable-banner2.enable-b2nh.enable-b2nm.is-home 
		{
			--main-content-translate-y: var(--banner2-content-height-home-desktop)
		}
	}
	@media (max-width: 768px) {
		body.enable-banner2.is-home, 
		body.enable-banner2.enable-b2nh.is-home,
		body.enable-banner2.enable-b2nm.is-home,
		body.enable-banner2.enable-b2nh.enable-b2nm.is-home 
		{
			--main-content-translate-y: var(--banner2-content-height-home-mobile)
		}
	}

	.enable-banner2 .main-content { 
		transform: translateY(var(--main-content-translate-y));
		transition: transform 0.3s ease-in-out;
		will-change: transform;
	}

	body.enable-banner2 {
		--main-content-translate-y: var(--main-panel-top)
	}
	
	@media (min-width: 769px) {
		body.enable-banner2.enable-b2nh {
			--main-content-translate-y: var(--banner2-content-height-nonhome-desktop)
		}
	}
	@media (max-width: 768px) {
		body.enable-banner2.enable-b2nm {
			--main-content-translate-y: var(--banner2-content-height-nonhome-mobile)
		}
	}

	/* 非主页 b2nh banner */
	@media (min-width: 769px) {
		.enable-banner2.enable-b2nh #banner2-container {
			height: var(--banner2-height-nonhome-desktop);
		}

		.enable-banner2.enable-b2nh .banner2-text {
			opacity: 0;
			transition: opacity 0.3s ease;
			will-change: opacity;
		}

		.enable-banner2.enable-b2nh.is-home .banner2-text {
			opacity: 1;
		}
	}
	@media (max-width: 768px) {
		.enable-banner2.enable-b2nm #banner2-container {
			height: var(--banner2-height-nonhome-mobile);
		}

		.enable-banner2.enable-b2nm .banner2-text {
			opacity: 0;
			transition: opacity 0.3s ease;
			will-change: opacity;
		}

		.enable-banner2.enable-b2nm.is-home .banner2-text {
			opacity: 1;
		}
	}
	
	/* 主页 */

	body {
		padding-bottom: var(--main-content-translate-y);
	}

	.enable-banner2.is-home #banner2-container {
		opacity: 1;
	}
	
	@media (min-width: 769px) {
		.enable-banner2.enable-b2nh #banner2-container {
			opacity: 1;
			transition: height 0.3s ease;
			will-change: height;
		}
	}
	@media (max-width: 768px) {
		.enable-banner2.enable-b2nm #banner2-container {
			opacity: 1;
			transition: height 0.3s ease;
			will-change: height;
		}
	}

	/* 其他组件的fix */

	.enable-banner2 #top-row {
		position: fixed;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		margin: 0;
		padding: 0;
		width: 100%;
	}

	.enable-banner2.is-home #top-row {
		position: fixed;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		margin: 0;
		padding: 0;
		width: 100%;
	}

    .enable-banner2 #sidebar-sticky {
        /* 4px是额外gap，
        banner2-height是main-content为banner的主动translate */
        top: calc(4px - var(--main-content-translate-y));
        /* top: 0 !important; */
    }

    .enable-banner2.is-home #sidebar-sticky {
        /* 修正main content的translate后，额外保留1rem视觉空间 */
        top: calc(1rem - var(--main-content-translate-y));
    }
}
@layer components {
	:root.is-home details#toc-wrapper {
		opacity: 0;
		pointer-events: none;
	}
}
</style>

