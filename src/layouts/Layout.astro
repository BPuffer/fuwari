function showBanner() {
	if (!siteConfig.banner.enable) return;

	const banner = document.getElementById('banner');
	if (!banner) {
		console.error('Banner element not found');
		return;
	}

	banner.classList.remove('opacity-0', 'scale-105');
}

function showBanner2() { // 这里开始插入图片src
	let srcType: string;
	let randomImg: { path: string; credit: { url: string; text: string; }; };
	if (window.innerWidth < 768) {
		if (document.querySelector('html.dark')) srcType = "dm"
		else srcType = "lm"
	} else if (document.querySelector('html.dark')) srcType = "dd"
	else srcType = "ld"
	srcType = `banner2${srcType}imgsrc`
	try {
		const metaTag: HTMLMetaElement | null = document.querySelector('meta[name="banner2ImgSrc"]');
		if (metaTag?.dataset[srcType]) {
			const imgArray = JSON.parse(metaTag.dataset[srcType] || "[]");
			randomImg = imgArray[Math.floor(Math.random() * imgArray.length)];
		} else {
			console.error("metaTag: ", metaTag);
			throw new Error("banner2ImgSrc meta tag is missing or empty");
		}
		// 立即改背景
		(document.querySelector('.banner2-banner') as HTMLElement)?.style.setProperty('--banner2-track-bg', `url(${randomImg.path})`);
		// 立即改credit
		const creditLink = document.querySelector(".banner2-credit-a");
		const creditText = document.querySelector(".banner2-credit-text");
		if (!creditLink || !creditText) return;
		if (randomImg.credit) {
			creditLink.setAttribute("href", randomImg.credit.url);
			creditLink.setAttribute("target", "_blank");
			creditText.textContent = randomImg.credit.text || "图片版权信息";
		} else {
			(creditLink as HTMLElement).style.display = "none";
		}
	} catch (error) {
		console.error("Failed to parse banner2ImgSrc from meta tag:", error);
		throw error;
	}
}

function initCommentComponent() {
  const event = new Event("loadComment");
  document.dispatchEvent(event);
}

function init() {
	// disableAnimation()()		// TODO
	loadTheme();
	loadHue();
	initCustomScrollbar();
	showBanner();
	showBanner2();
	initCommentComponent();
}


/* Load settings when entering the site */
init();

const setup = () => {
