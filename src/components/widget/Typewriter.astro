---
/**
 * WARN: This file is completely generated by AI.
 *
 * Typewriter component
 * @param {string[]} textList - List of texts to be typed
 * @param {number} [speed=100] - Typing speed in milliseconds
 * @param {number} [delay=1000] - Delay for text completely showing in milliseconds
 * @param {string} [className=""] - Additional class names for the component
 * @param {string} [placeholder="▏"] - Placeholder character for the cursor，"" to disable cursor
 */
interface Props {
	textList: string[];
	speed?: number;
	delay?: number;
	placeholder?: string;
	class?: string;
}

const {
	textList,
	speed = 100,
	delay = 1500,
	placeholder = "▏",
	class: className = "",
} = Astro.props;
---
<span class={`typewriter-container ${className}`} 
     data-text-list={JSON.stringify(textList)} 
     data-speed={speed} 
     data-delay={delay}>
  <span class="typewriter-text whitespace-pre-wrap"></span>
  {placeholder && <span class="typewriter-cursor">{placeholder}</span>}
</span>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const textElements = document.querySelectorAll('.typewriter-text');
    
    textElements.forEach((element) => {
      const container = element.closest('.typewriter-container');
      if (!container) return;
      
      // 获取组件属性
      const textList = {text: {list: JSON.parse(container.getAttribute('data-text-list') || '[]')}};
      const speed = parseInt(container.getAttribute('data-speed') || '100');
      const delay = parseInt(container.getAttribute('data-delay') || '1000');
      
      let currentTextIndex = 0;
      let currentCharIndex = 0;
      let isDeleting = false;
      let isPausing = false;
      
      function type() {
        if (isPausing) return;
        
        const currentText = textList.text.list[currentTextIndex];
        
        if (isDeleting) {
          // 删除字符
          element.textContent = currentText.substring(0, currentCharIndex - 1);
          currentCharIndex--;
          
          if (currentCharIndex === 0) {
            // 删除完成，切换到下一个文本
            isDeleting = false;
            currentTextIndex = (currentTextIndex + 1) % textList.text.list.length;
            // 短暂停顿后开始新文本
            isPausing = true;
            setTimeout(() => {
              isPausing = false;
              type();
            }, 500);
            return;
          }
        } else {
          // 打出字符
          element.textContent = currentText.substring(0, currentCharIndex + 1);
          currentCharIndex++;
          
          if (currentCharIndex === currentText.length) {
            // 打字完成，停留delay时间后开始删除
            isPausing = true;
            setTimeout(() => {
              isPausing = false;
              isDeleting = true;
              type();
            }, delay);
            return;
          }
        }
        
        // 控制打字速度，删除时速度更快
        const typeSpeed = isDeleting ? speed / 2 : speed;
        setTimeout(type, typeSpeed);
      }
      
      // 开始打字效果
      type();
    });
  });
</script>

<style>
  .typewriter-cursor {
    display: inline-block;
    animation: blink 1s infinite;
    margin-left: 0;
  }
  
  @keyframes blink {
    0%, 50% {
      opacity: 1;
    }
    51%, 100% {
      opacity: 0;
    }
  }
</style>